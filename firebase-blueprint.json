
{
  "entities": {
    "Contract": {
      "title": "Contract",
      "type": "object",
      "description": "Represents a project contract with full lifecycle auditing and schedule tracking.",
      "properties": {
        "id": { "type": "string" },
        "projectName": { "type": "string" },
        "name": { "type": "string" },
        "signingUnit": { "type": "string" },
        "price": { "type": "number", "description": "立项金额" },
        "contractPrice": { "type": "number", "description": "合同价 (签约额)" },
        "budgetAmount": { "type": "number", "description": "预算送审金额" },
        "priceAudit": { "type": "number", "description": "预算审核金额" },
        "settlementPrice": { "type": "number", "description": "结算送审金额" },
        "settlementAuditPrice": { "type": "number", "description": "结算审核金额 (审定价)" },
        "fundingChannel": { "type": "string" },
        "type": { "type": "string", "enum": ["工程合同", "采购合同"] },
        "startDate": { "type": "string", "format": "date", "description": "开工日期" },
        "completionDate": { "type": "string", "format": "date", "description": "竣工日期" },
        "endDate": { "type": "string", "format": "date", "description": "合同终止日期 (维保到期)" },
        "acceptanceDate": { "type": "string", "format": "date", "description": "验收日期" },
        "initiationDate": { "type": "string", "format": "date", "description": "立项日期" },
        "budgetSubmissionDate": { "type": "string", "format": "date", "description": "预算送审日期" },
        "budgetDate": { "type": "string", "format": "date", "description": "预算审核日期" },
        "settlementDate": { "type": "string", "format": "date", "description": "结算送审日期" },
        "settlementAuditDate": { "type": "string", "format": "date", "description": "结算审定日期" },
        "plannedDuration": { "type": "number", "description": "计划工期 (天)" },
        "totalPaid": { "type": "number" },
        "paymentSummary": { "type": "string", "description": "支付流水摘要" },
        "orderIndex": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "projectName", "name", "price", "contractPrice", "fundingChannel", "type"]
    },
    "UserMetadata": {
      "title": "UserMetadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "registeredAt": { "type": "string" },
        "expiresAt": { "type": "number" }
      }
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "adminReply": { "type": "string" },
        "createdAt": { "type": "number" },
        "repliedAt": { "type": "number" }
      }
    },
    "AuditLog": {
      "title": "AuditLog",
      "type": "object",
      "description": "System operation logs for auditing purposes.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}/contracts/{contractId}": {
      "schema": "#/entities/Contract",
      "description": "User contracts with full auditing history."
    },
    "/users_metadata/{userId}": {
      "schema": "#/entities/UserMetadata",
      "description": "User access metadata."
    },
    "/support_tickets/{ticketId}": {
      "schema": "#/entities/SupportTicket",
      "description": "Support tickets."
    },
    "/audit_logs/{logId}": {
      "schema": "#/entities/AuditLog",
      "description": "System operation logs."
    }
  }
}
